<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <style>
    * { box-sizing: border-box; margin: 0; padding: 0; }
    body { font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif; background-color: #f1f5f9; color: #334155; }
    .wrapper { max-width: 600px; margin: 32px auto; background: #ffffff; border-radius: 12px; overflow: hidden; box-shadow: 0 4px 24px rgba(0,0,0,0.08); }
    .header { background: linear-gradient(135deg, #064e3b 0%, #059669 100%); padding: 28px 32px; display: flex; align-items: center; gap: 16px; }
    .header img.logo { height: 44px; width: auto; border-radius: 6px; background: #fff; padding: 4px; }
    .header-text h1 { color: #ffffff; font-size: 18px; font-weight: 700; }
    .header-text p { color: rgba(255,255,255,0.75); font-size: 12px; margin-top: 2px; }
    .body { padding: 32px; }
    .greeting { font-size: 15px; color: #1e293b; margin-bottom: 20px; }
    .stats-row { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; margin-top: 20px; }
    .stat-card { background: #f8fafc; border: 1px solid #e2e8f0; border-radius: 10px; padding: 18px 20px; text-align: center; }
    .stat-label { font-size: 11px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.5px; color: #94a3b8; margin-bottom: 8px; }
    .stat-value { font-size: 28px; font-weight: 800; color: #0f172a; }
    .stat-unit { font-size: 12px; color: #64748b; margin-left: 2px; }
    .stat-card.highlight .stat-value { color: #2563eb; }
    .stat-card.overtime .stat-value { color: #d97706; }
    .info-card { margin-top: 20px; background: #f8fafc; border: 1px solid #e2e8f0; border-radius: 10px; overflow: hidden; }
    .info-row { display: flex; align-items: center; padding: 12px 20px; border-bottom: 1px solid #e2e8f0; }
    .info-row:last-child { border-bottom: none; }
    .info-label { width: 140px; font-size: 11px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.5px; color: #94a3b8; flex-shrink: 0; }
    .info-value { font-size: 14px; font-weight: 600; color: #0f172a; }
    .message { margin-top: 24px; padding: 16px 20px; background: #ecfdf5; border: 1px solid #a7f3d0; border-radius: 10px; border-left: 4px solid #10b981; font-size: 13px; color: #065f46; line-height: 1.6; }
    .footer { background: #0f172a; padding: 24px 32px; }
    .footer-company { font-size: 13px; font-weight: 700; color: #ffffff; margin-bottom: 4px; }
    .footer-address { font-size: 11px; color: #94a3b8; line-height: 1.6; }
    .footer-divider { border: none; border-top: 1px solid #1e293b; margin: 16px 0; }
    .footer-copy { font-size: 11px; color: #475569; text-align: center; }
  </style>
</head>
<body>
  <div class="wrapper">
    <!-- Header -->
    <div class="header">
      {{#if companyLogo}}
        <img class="logo" src="{{companyLogo}}" alt="{{companyName}}" />
      {{/if}}
      <div class="header-text">
        <h1>{{companyName}}</h1>
        <p>Attendance Management System</p>
      </div>
    </div>

    <!-- Body -->
    <div class="body">
      <p class="greeting">Hello, <strong>{{name}}</strong></p>
      <p style="font-size:14px;color:#475569;">Your check-out for <strong>{{date}}</strong> has been recorded. Here's your daily summary.</p>

      <!-- Stats -->
      <div class="stats-row">
        <div class="stat-card highlight">
          <div class="stat-label">Total Hours</div>
          <div class="stat-value">{{workHours}}<span class="stat-unit">h</span></div>
        </div>
        <div class="stat-card overtime">
          <div class="stat-label">Overtime</div>
          <div class="stat-value">{{overtime}}<span class="stat-unit">h</span></div>
        </div>
      </div>

      <!-- Info -->
      <div class="info-card">
        <div class="info-row">
          <span class="info-label">Check-Out Time</span>
          <span class="info-value">{{time}}</span>
        </div>
        <div class="info-row">
          <span class="info-label">Date</span>
          <span class="info-value">{{date}}</span>
        </div>
      </div>

      <div class="message">
        🎉 Great work today, <strong>{{name}}</strong>! Your dedication is appreciated. Rest well and we'll see you tomorrow.
      </div>
    </div>

    <!-- Footer -->
    <div class="footer">
      {{#if companyAddress}}
        <p class="footer-company">{{companyName}}</p>
        <p class="footer-address">📍 {{companyAddress}}{{#if companyEmail}} &nbsp;|&nbsp; ✉️ {{companyEmail}}{{/if}}</p>
      {{/if}}
      <hr class="footer-divider" />
      <p class="footer-copy">This is an automated message. &copy; {{companyName}}. All rights reserved.</p>
    </div>
  </div>
</body>
</html>
