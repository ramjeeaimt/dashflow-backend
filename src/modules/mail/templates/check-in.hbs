<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <style>
    body {font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif; background:#f9fafb; color:#1e293b; padding:20px;}
    .wrapper {max-width:600px;margin:auto;background:#fff;padding:24px;border-radius:8px;box-shadow:0 2px 8px rgba(0,0,0,0.08);}
    h1 {font-size:20px;color:#2563eb;margin-bottom:12px;}
    p {margin:8px 0;line-height:1.5;}
    .footer {font-size:12px;color:#64748b;margin-top:24px;border-top:1px solid #e2e8f0;padding-top:12px;}
  </style>
</head>
<body>
  <div class="wrapper">
    <h1>Check‑in Successful</h1>
    <p>Dear {{name}},</p>
    <p>Your check‑in has been recorded for <strong>{{date}}</strong> at <strong>{{time}}</strong>.</p>
    <p>Status: <strong>{{status}}</strong></p>
    <p>Thank you for using the attendance system.</p>
    <div class="footer">
      This is an automated message from {{companyName}}.
    </div>
  </div>
</body>
</html>
