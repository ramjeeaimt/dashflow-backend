<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <style>
    * { box-sizing: border-box; margin: 0; padding: 0; }
    body { font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif; background-color: #f1f5f9; color: #334155; }
    .wrapper { max-width: 600px; margin: 32px auto; background: #ffffff; border-radius: 12px; overflow: hidden; box-shadow: 0 4px 24px rgba(0,0,0,0.08); }
    /* Header */
    .header { background: linear-gradient(135deg, #1e3a5f 0%, #2563eb 100%); padding: 28px 32px; display: flex; align-items: center; gap: 16px; }
    .header img.logo { height: 44px; width: auto; border-radius: 6px; }
    .header-text h1 { color: #ffffff; font-size: 18px; font-weight: 700; letter-spacing: -0.3px; }
    .header-text p { color: rgba(255,255,255,0.7); font-size: 12px; margin-top: 2px; }
    /* Warning banner */
    .late-banner { background: #fef2f2; border-left: 4px solid #dc2626; padding: 14px 24px; display: flex; align-items: flex-start; gap: 12px; }
    .late-banner .icon { font-size: 20px; flex-shrink: 0; margin-top: 1px; }
    .late-banner .text strong { display: block; font-size: 14px; font-weight: 700; color: #991b1b; }
    .late-banner .text span { font-size: 13px; color: #b91c1c; }
    /* Body */
    .body { padding: 32px; }
    .greeting { font-size: 15px; color: #1e293b; margin-bottom: 20px; }
    .greeting strong { font-weight: 700; }
    .info-card { background: #f8fafc; border: 1px solid #e2e8f0; border-radius: 10px; overflow: hidden; margin-top: 20px; }
    .info-row { display: flex; align-items: center; padding: 14px 20px; border-bottom: 1px solid #e2e8f0; }
    .info-row:last-child { border-bottom: none; }
    .info-label { width: 130px; font-size: 11px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.5px; color: #94a3b8; flex-shrink: 0; }
    .info-value { font-size: 14px; font-weight: 600; color: #0f172a; }
    .badge { display: inline-block; padding: 3px 12px; border-radius: 20px; font-size: 11px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.5px; }
    .badge-late { background: #fee2e2; color: #991b1b; }
    .badge-present { background: #dcfce7; color: #166534; }
    .badge-early { background: #dbeafe; color: #1d4ed8; }
    .badge-wfh { background: #f3e8ff; color: #7e22ce; }
    .message { font-size: 14px; color: #64748b; line-height: 1.7; margin-top: 24px; padding: 16px; background: #f8fafc; border-radius: 8px; border: 1px solid #e2e8f0; }
    /* Footer */
    .footer { background: #0f172a; padding: 24px 32px; }
    .footer-company { font-size: 13px; font-weight: 700; color: #ffffff; margin-bottom: 4px; }
    .footer-address { font-size: 11px; color: #94a3b8; line-height: 1.6; }
    .footer-divider { border: none; border-top: 1px solid #1e293b; margin: 16px 0; }
    .footer-copy { font-size: 11px; color: #475569; text-align: center; }
  </style>
</head>
<body>
  <div class="wrapper">
    <!-- Header -->
    <div class="header">
      {{#if companyLogo}}
        <img class="logo" src="{{companyLogo}}" alt="{{companyName}} logo" />
      {{/if}}
      <div class="header-text">
        <h1>{{companyName}}</h1>
        <p>Attendance Management System</p>
      </div>
    </div>

    <!-- Late Warning Banner -->
    {{#if isLate}}
    <div class="late-banner">
      <span class="icon">⚠️</span>
      <div class="text">
        <strong>Late Check-in Recorded</strong>
        <span>Your check-in has been marked as late. Please note this in your attendance record.</span>
      </div>
    </div>
    {{/if}}

    <!-- Body -->
    <div class="body">
      <p class="greeting">Hello, <strong>{{name}}</strong></p>
      <p style="font-size:14px;color:#475569;">Your attendance has been recorded for <strong>{{date}}</strong>.</p>

      <div class="info-card">
        <div class="info-row">
          <span class="info-label">Date</span>
          <span class="info-value">{{date}}</span>
        </div>
        <div class="info-row">
          <span class="info-label">Check-In Time</span>
          <span class="info-value">{{time}}</span>
        </div>
        <div class="info-row">
          <span class="info-label">Status</span>
          <span class="info-value">
            {{#if (eq status 'late')}}<span class="badge badge-late">Late</span>{{/if}}
            {{#if (eq status 'present')}}<span class="badge badge-present">Present</span>{{/if}}
            {{#if (eq status 'early_checkin')}}<span class="badge badge-early">Early Check-in</span>{{/if}}
            {{#if (eq status 'wfh')}}<span class="badge badge-wfh">Work From Home</span>{{/if}}
          </span>
        </div>
      </div>

      {{#if isLate}}
      <div class="message" style="border-color:#fecaca;background:#fef9f9;">
        ⚠️ <strong>Attendance Notice:</strong> Your check-in was recorded after your scheduled start time. Repeated late arrivals may impact your performance review and payroll deductions. Please ensure timely attendance going forward.
      </div>
      {{else}}
      <div class="message">
        ✅ Great start! Your check-in has been successfully recorded. Have a productive day!
      </div>
      {{/if}}
    </div>

    <!-- Footer -->
    <div class="footer">
      {{#if companyAddress}}
        <p class="footer-company">{{companyName}}</p>
        <p class="footer-address">📍 {{companyAddress}}{{#if companyEmail}} &nbsp;|&nbsp; ✉️ {{companyEmail}}{{/if}}</p>
      {{/if}}
      <hr class="footer-divider" />
      <p class="footer-copy">This is an automated message. &copy; {{companyName}}. All rights reserved.</p>
    </div>
  </div>
</body>
</html>
